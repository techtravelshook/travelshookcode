// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// model for umrah
model UmrahPackage {
  id           Int                @id @default(autoincrement())
  title        String
  slug         String             @unique
  shortDesc    String             @db.Text
  description  String             @db.Text
  star         PackageStar
  type         PackageType
  month        String?
  duration     Int
  makkahHotel  String
  madinahHotel String
  price        Float
  isFeatured   Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  images       PackageImage[]
  inclusions   PackageInclusion[]
  exclusions   PackageExclusion[]

  
  @@index([type])
  @@index([star])
  @@index([type, star])
}

// aother model
model PackageImage {
  id        Int          @id @default(autoincrement())
  url       String
  packageId Int
  package   UmrahPackage @relation(fields: [packageId], references: [id])
}

model PackageInclusion {
  id        Int          @id @default(autoincrement())
  title     String
  packageId Int
  package   UmrahPackage @relation(fields: [packageId], references: [id])
}

model PackageExclusion {
  id        Int          @id @default(autoincrement())
  title     String
  packageId Int
  package   UmrahPackage @relation(fields: [packageId], references: [id])
}

enum PackageStar {
  STAR_1
  STAR_2
  STAR_3
  STAR_4
  STAR_5
}

enum PackageType {
  RAMADAN
  MONTHLY
  NORMAL
  WOMEN
  LUXURY
  CHEAP
  
}

enum HolidayType {
 HOLIDAY
  CITY_BREAK
  INCLUSIVE_HOLIDAY
  BEACH_HOLIDAY
  FAMILY_HOLIDAY
  Last_Minute_Holidays
}
// FOR HOLIDAY'S
model HolidayPackage {
  id           Int                   @id @default(autoincrement())
  title        String
  slug         String                @unique
  shortDesc    String                @db.Text
  description  String                @db.Text
  star         PackageStar
  type         HolidayType
  month        String?
  duration     Int
  makkahHotel  String?
  madinahHotel String?
  price        Float
  isFeatured   Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  packages     HolidayPackageItem[]
  images       HolidayPackageImage[]
}

// model for Holiday Images
model HolidayPackageImage {
  id               Int            @id @default(autoincrement())
  url              String
  slideTitle       String?
  slideDesc        String?
  holidayPackageId Int
  holidayPackage   HolidayPackage @relation(fields: [holidayPackageId], references: [id])
}

model HolidayPackageItem {
  id               Int            @id @default(autoincrement())
  holidayPackageId Int
  holidayPackage   HolidayPackage @relation(fields: [holidayPackageId], references: [id])
  title            String
  subtitle         String?
  description      String?        @db.Text
  image            String?
  price            Float
  originalPrice    Float?
  rating           Float?
  reviews          Int?
  duration         String?
  accent           String?
}

model HolidayBreaks {
  id        Int         @id @default(autoincrement())
  title     String
  category  String
  shortDesc String      @db.Text
  rating    PackageStar
  type      HolidayType
  month     String?
  duration  Int
  price     Float

  images   HolidayBreakImage[]
  features HolidayBreakFeatures[]
}

model HolidayBreakImage {
  id  Int    @id @default(autoincrement())
  url String

  holidayBreakId Int
  holidayBreak   HolidayBreaks @relation(fields: [holidayBreakId], references: [id])
}

model HolidayBreakFeatures {
  id             Int           @id @default(autoincrement())
  name           String
  holidayBreakId Int
  holidayBreak   HolidayBreaks @relation(fields: [holidayBreakId], references: [id])
}

//*********FLIGHTS SCHEMA*************//

model Flight {
  id              Int      @id @default(autoincrement())
  slug         String             @unique
  tripType        String   // "one-way" or "return"
  airlineName     String
  apiType          String
  airlineLogo     String   // Path or URL to logo
  departureCode   String   // e.g., "MAN", "LHR"
  departureCity   String   // e.g., "Manchester", "London"
  destinationCode String   // e.g., "ACC"
  destinationCity String   // e.g., "Accra"
  price           Float
  dates           String   // e.g., "17 Oct 2026" or "11 Jun - 10 Jul"
  createdAt       DateTime @default(now())
}
// for Flight content
model CountryContent {
  id              Int    @id @default(autoincrement())
  slug            String @unique
   apiType          String
  section1Title   String
  section1img     String
  section2img     String
  section1Content String @db.Text
  section2Title   String
  section2Content String @db.Text
  faqs            Json   // Stores the entire FAQ list as a clean array
}
////////////////////////
////****HONEYMOON SEED*******
/////////////////////////



model Package {
  id             Int             @id @default(autoincrement())
  title          String
  slug           String          @unique
  shortDesc      String          @db.Text
  description    String          @db.Text
  price          Int
  durationDays   Int
  durationNights Int
  month          String
  star           Int
  type           String
  country        String
  city           String
  category       String
  featured       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relationships
  hotels         Hotel[]
  images         Image[]
  flights        FlightDetail ?
  transportation Transportation?
  visaAssistance VisaAssistance?
  sightseeing    Sightseeing?
}

model Hotel {
  id             Int     @id @default(autoincrement())
  name           String
  city           String
  durationNights Int
  starRating     Int
  roomType       String
  description    String  @db.Text
  packageId      Int
  package        Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Image {
  id        Int     @id @default(autoincrement())
  url       String
  packageId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model FlightDetail  {
  id              Int     @id @default(autoincrement())
  departureCities Json    // Saves array: ["Lahore", "Islamabad", "Karachi"]
  destination     String
  airlines        Json    // Saves array: ["Emirates", "Qatar Airways"]
  classOption     String
  packageId       Int     @unique
  package         Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Transportation {
  id           Int     @id @default(autoincrement())
  type         String
  routeDetails String  @db.Text
  extras       String  @db.Text
  packageId    Int     @unique
  package      Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model VisaAssistance {
  id                Int     @id @default(autoincrement())
  supportedRegion   String
  agency            String
  requiredDocuments Json    // Saves array: ["Valid passport", "Photos"]
  packageId         Int     @unique
  package           Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Sightseeing {
  id                  Int     @id @default(autoincrement())
  items               Json    // Saves array of activities
  romanticExperiences Json    // Saves array of romantic options
  guideIncluded       Boolean @default(true)
  packageId           Int     @unique
  package             Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}