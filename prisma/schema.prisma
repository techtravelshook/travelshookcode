generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model UmrahPackage {
  id           Int                @id @default(autoincrement())
  title        String
  slug         String             @unique
  shortDesc    String             @db.Text
  description  String             @db.Text
  star         PackageStar
  type         PackageType
  month        String?
  duration     Int
  makkahHotel  String
  madinahHotel String
  price        Float
  isFeatured   Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  exclusions   PackageExclusion[]
  images       PackageImage[]
  inclusions   PackageInclusion[]

  @@index([type])
  @@index([star])
  @@index([type, star])
}

model PackageImage {
  id        Int          @id @default(autoincrement())
  url       String
  packageId Int
  package   UmrahPackage @relation(fields: [packageId], references: [id])

  @@index([packageId], map: "PackageImage_packageId_fkey")
}

model PackageInclusion {
  id        Int          @id @default(autoincrement())
  title     String
  packageId Int
  package   UmrahPackage @relation(fields: [packageId], references: [id])

  @@index([packageId], map: "PackageInclusion_packageId_fkey")
}

model PackageExclusion {
  id        Int          @id @default(autoincrement())
  title     String
  packageId Int
  package   UmrahPackage @relation(fields: [packageId], references: [id])

  @@index([packageId], map: "PackageExclusion_packageId_fkey")
}

model HolidayPackage {
  id           Int                   @id @default(autoincrement())
  title        String
  slug         String                @unique
  shortDesc    String                @db.Text
  description  String                @db.Text
  star         PackageStar
  type         HolidayType
  month        String?
  duration     Int
  makkahHotel  String?
  madinahHotel String?
  price        Float
  isFeatured   Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  images       HolidayPackageImage[]
  packages     HolidayPackageItem[]
}

model HolidayPackageImage {
  id               Int            @id @default(autoincrement())
  url              String
  slideTitle       String?
  slideDesc        String?
  holidayPackageId Int
  holidayPackage   HolidayPackage @relation(fields: [holidayPackageId], references: [id])

  @@index([holidayPackageId], map: "HolidayPackageImage_holidayPackageId_fkey")
}

model HolidayPackageItem {
  id               Int            @id @default(autoincrement())
  holidayPackageId Int
  title            String
  subtitle         String?
  description      String?        @db.Text
  image            String?
  price            Float
  originalPrice    Float?
  rating           Float?
  reviews          Int?
  duration         String?
  accent           String?
  holidayPackage   HolidayPackage @relation(fields: [holidayPackageId], references: [id])

  @@index([holidayPackageId], map: "HolidayPackageItem_holidayPackageId_fkey")
}

model HolidayBreaks {
  id              Int                    @id @default(autoincrement())
  title           String
  category        String
  shortDesc       String                 @db.Text
  rating          PackageStar
  type            HolidayType
  month           String?
  duration        Int
  price           Float
  bestTimeToVisit String?
  desc            String?
  location        String?
  highlights      Highlight[]
  features        HolidayBreakFeatures[]
  images          HolidayBreakImage[]
}

model Highlight {
  id             Int           @id @default(autoincrement())
  name           String
  holidayBreakId Int
  holidayBreak   HolidayBreaks @relation(fields: [holidayBreakId], references: [id], onDelete: Cascade)

  @@index([holidayBreakId], map: "Highlight_holidayBreakId_fkey")
}

model HolidayBreakImage {
  id             Int           @id @default(autoincrement())
  url            String
  holidayBreakId Int
  holidayBreak   HolidayBreaks @relation(fields: [holidayBreakId], references: [id])

  @@index([holidayBreakId], map: "HolidayBreakImage_holidayBreakId_fkey")
}

model HolidayBreakFeatures {
  id             Int           @id @default(autoincrement())
  name           String
  holidayBreakId Int
  holidayBreak   HolidayBreaks @relation(fields: [holidayBreakId], references: [id])

  @@index([holidayBreakId], map: "HolidayBreakFeatures_holidayBreakId_fkey")
}

model Flight {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  tripType        String
  airlineName     String
  apiType         String
  airlineLogo     String
  departureCode   String
  departureCity   String
  destinationCode String
  destinationCity String
  price           Float
  dates           String
  createdAt       DateTime @default(now())
}

model CountryContent {
  id              Int    @id @default(autoincrement())
  slug            String @unique
  apiType         String
  section1Title   String
  section1img     String
  section2img     String
  section1Content String @db.Text
  section2Title   String
  section2Content String @db.Text
  faqs            String @db.LongText
}

model Package {
  id             Int             @id @default(autoincrement())
  title          String
  slug           String          @unique
  shortDesc      String          @db.Text
  description    String          @db.Text
  price          Int
  durationDays   Int
  durationNights Int
  month          String
  star           Int
  type           String
  country        String
  city           String
  category       String
  featured       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  flights        FlightDetail?
  hotels         Hotel[]
  images         Image[]
  sightseeing    Sightseeing?
  transportation Transportation?
  visaAssistance VisaAssistance?
}

model Hotel {
  id             Int     @id @default(autoincrement())
  name           String
  city           String
  durationNights Int
  starRating     Int
  roomType       String
  description    String  @db.Text
  packageId      Int
  package        Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId], map: "Hotel_packageId_fkey")
}

model Image {
  id        Int     @id @default(autoincrement())
  url       String
  packageId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId], map: "Image_packageId_fkey")
}

model FlightDetail {
  id              Int     @id @default(autoincrement())
  departureCities String  @db.LongText
  destination     String
  airlines        String  @db.LongText
  classOption     String
  packageId       Int     @unique
  package         Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Transportation {
  id           Int     @id @default(autoincrement())
  type         String
  routeDetails String  @db.Text
  extras       String  @db.Text
  packageId    Int     @unique
  package      Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model VisaAssistance {
  id                Int     @id @default(autoincrement())
  supportedRegion   String
  agency            String
  requiredDocuments String  @db.LongText
  packageId         Int     @unique
  package           Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Sightseeing {
  id                  Int     @id @default(autoincrement())
  items               String  @db.LongText
  romanticExperiences String  @db.LongText
  guideIncluded       Boolean @default(true)
  packageId           Int     @unique
  package             Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model TopDestinations {
  id              String @id @default(uuid())
  title           String @db.VarChar(255)
  country         String @db.VarChar(100)
  category        String @db.VarChar(50)
  image           String @db.VarChar(500)
  rating          Int
  duration        String @db.VarChar(50)
  features        String @db.LongText
  trustpilotScore Int
  price           Int
  location        String @db.VarChar(255)
  bestTimeToVisit String @db.VarChar(255)
  highlights      String @db.LongText
  shortDesc       String @db.VarChar(1000)
  desc            String @db.LongText
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullname  String?
  createdAt DateTime @default(now())
}

model admin {
  id        String   @id @default(cuid())
  name      String
  emails    String   @unique
  password  String
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PackageStar {
  STAR_1
  STAR_2
  STAR_3
  STAR_4
  STAR_5
}

enum PackageType {
  RAMADAN
  MONTHLY
  NORMAL
  WOMEN
  LUXURY
  CHEAP
}

enum HolidayType {
  HOLIDAY
  CITY_BREAK
  INCLUSIVE_HOLIDAY
  BEACH_HOLIDAY
  FAMILY_HOLIDAY
  Last_Minute_Holidays
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model Blog {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String    @db.Text
  content     String    @db.LongText
  coverImage  String                    // hero/background image
  category    String
  author      String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  faqs        BlogFaq[]
  images      BlogImage[]
}

model BlogImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String   @default("")       // SEO — always fill this
  caption   String?                     // optional caption under image
  paragraph Int      @default(0)        // which paragraph this image belongs to (0 = general)
  order     Int      @default(0)        // display order within that paragraph
  blogId    Int
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model BlogFaq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  blogId    Int
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}